{
  "name": "paladin",
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260304.1",
    "bun-types": "latest",
    "dependency-cruiser": "^17.3.10",
    "jscodeshift": "^17.3.0"
  },
  "private": true,
  "scripts": {
    "dev": "bun run --filter '@paladin/{api,web}' dev",
    "dev:web": "bun run --filter '@paladin/web' dev",
    "dev:api": "bun run --filter '@paladin/api' dev",
    "build:web": "bun run --filter '@paladin/web' build",
    "build:extension": "bun run --filter '@paladin/claude-chat-downloader' build",
    "lint": "tsgo --noEmit",
    "scaffold": "bun run --filter '@paladin/scaffold' start",
    "dev:scaffold": "bun run --filter '@paladin/scaffold' dev",
    "bootstrap": "bun run --filter '@paladin/bootstrap' start",
    "bootstrap:local": "bun run --filter '@paladin/bootstrap' run",
    "dev:scribe": "bun run --filter '@paladin/{scribe-ui,scribe-api}' dev",
    "dev:scribe-ui": "bun run --filter '@paladin/scribe-ui' dev",
    "dev:scribe-api": "bun run --filter '@paladin/scribe-api' dev"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@swc/core": "^1.15.21"
  },
  "overrides": {
  "react": "^19.2.4",
  "react-dom": "^19.2.4"
}
}
