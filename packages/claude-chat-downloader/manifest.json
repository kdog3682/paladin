{
  "manifest_version": 3,
  "name": "Claude Chat Downloader",
  "version": "0.2.6",
  "description": "Download chat history as JSON.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "https://claude.ai/*"
      ]
    }
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ]
}
