
{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM"
    ],
    "module": "esnext",
    "target": "esnext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "strict": true,
    "downlevelIteration": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "types": [
      "bun-types"
    ],
    "paths": {
      "@paladin/*": [
        "./packages/*/src"
      ]
    }
  },
  "exclude": [
    "scripts",
    "apps/claude-chat-downloader",
    "packages/ai",
    "packages/codeform"
  ]
}
