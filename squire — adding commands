# @paladin/squire — adding commands

structure:
  root: packages/squire/src
  commands_dir: commands/
  index: commands/index.ts
  handler_types: handler.ts

command_interface:
  name: string           # what the user types
  description: string    # shown in help
  requiresPkg: boolean   # if true, ctx.state.pkgDir is guaranteed non-null
  handler: "(args: string, ctx: CommandContext) => Promise<void | string>"

context:
  state:
    pkg: "current package name"
    pkgDir: "absolute path to package dir"
    demo: boolean
    test: boolean
  git: "GitOps — commit, revert, status"
  reporter: "Reporter — info(), success(), warn(), error(), header(), blank(), prompt()"
  runner: "Runner — runDemo(file), runTests(files, pkgDir?)"
  tempWriter: "TempWriter — active, clear(), append()"
  root: "monorepo root path"
  onSetPkg: "(name?: string) => Promise<{ name, dir } | null>"

return_values:
  void: "default — continue the loop"
  exit: "close readline and process.exit"
  restart: "re-run init, re-pick package"

args:
  note: "string after the command name, may be undefined"
  guard: "always check: args && typeof args === 'string' && args.trim()"

steps:
  - file: "create commands/<name>.ts"
    template: |
      import type { Command } from "../handler"

      export const fooCommand: Command = {
        name: "foo",
        description: "does the thing",
        requiresPkg: true,
        handler: async (args, ctx) => {
          ctx.reporter.info("hello from foo")
        },
      }

  - file: "update commands/index.ts"
    do: |
      1. add: export { fooCommand } from "./foo"
      2. add fooCommand to the base array

  - done: "command is auto-registered via the commands array. no changes to cli.ts needed"

patterns:
  run_shell: |
    const proc = Bun.spawn(["cmd", ...args], {
      cwd: ctx.state.pkgDir ?? ctx.root,
      stdout: "inherit",
      stderr: "inherit",
    })
    await proc.exited

  glob_files: |
    const glob = new Bun.Glob("**/*.ts")
    for await (const match of glob.scan({ cwd: ctx.state.pkgDir!, onlyFiles: true })) {
      // match is relative to pkgDir
    }

  switch_package: |
    const selected = await ctx.onSetPkg("other-pkg")
    if (selected) {
      ctx.state.pkg = selected.name
      ctx.state.pkgDir = selected.dir
    }

notes:
  - errors are caught by safeHandle in cli.ts — commands can throw freely
  - "dot syntax works automatically: pkg.foo runs set + foo"
  - "help command rebuilds from the base array — no manual help registration"
